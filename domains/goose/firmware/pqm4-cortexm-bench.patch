diff --git a/common/hal-opencm3.c b/common/hal-opencm3.c
index 05d7377..db4919b 100644
--- a/common/hal-opencm3.c
+++ b/common/hal-opencm3.c
@@ -1,6 +1,17 @@
 // SPDX-License-Identifier: Apache-2.0 or CC0-1.0
 #include "hal.h"
 #include <sys/cdefs.h>
+#ifdef SEMIHOSTING
+/* ARM semihosting SYS_WRITE0 (0x04): print null-terminated string via the debug
+ * probe. Lets us read benchmark output over SWD when the ST-Link VCP is not wired
+ * to the USART (the classic STM32F4DISCOVERY case). Enable in OpenOCD with
+ * "arm semihosting enable". */
+static void semihost_write0(const char *s) {
+  register int op asm("r0") = 0x04;
+  register const char *p asm("r1") = s;
+  asm volatile("bkpt 0xAB" : "+r"(op) : "r"(p) : "memory");
+}
+#endif
 
 #define SERIAL_BAUD 38400
 
@@ -362,12 +373,17 @@ void hal_setup(const enum clock_mode clock)
 
 void hal_send_str(const char* in)
 {
+#ifdef SEMIHOSTING
+  semihost_write0(in);
+  semihost_write0("\n");
+#else
   const char* cur = in;
   while (*cur) {
     usart_send_blocking(SERIAL_USART, *cur);
     cur += 1;
   }
   usart_send_blocking(SERIAL_USART, '\n');
+#endif
 }
 
 void sys_tick_handler(void)
