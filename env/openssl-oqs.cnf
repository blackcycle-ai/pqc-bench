# OpenSSL config for the GOOSE-PQC homogeneous stack.
# Activates the default provider (ML-DSA / SLH-DSA / ECDSA native in 3.5.x) AND the
# oqs-provider (Falcon / FN-DSA + composite hybrids). Point OPENSSL_CONF here.
openssl_conf = openssl_init

[openssl_init]
providers = provider_sect

[provider_sect]
default    = default_sect
oqsprovider = oqsprovider_sect

[default_sect]
activate = 1

[oqsprovider_sect]
activate = 1
